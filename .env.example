# ── Supabase ──
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<REDACTED_PUBLIC_KEY>
SUPABASE_SERVICE_KEY=<REDACTED_SECRET_KEY>
READONLY_DATABASE_URL=<REDACTED_DATABASE_CONNECTION_STRING>

# ── Redis (Docker) ──
REDIS_URL=redis://redis:6379

# ── AI & Tracing ──
GEMINI_API_KEY=<REDACTED_API_KEY>
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=<REDACTED_API_KEY>
LANGCHAIN_PROJECT=tickets-project

# ── General ──
ENVIRONMENT=development

# ── Frontend ──
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<REDACTED_PUBLIC_KEY>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<REDACTED_PUBLIC_KEY>
NEXT_PUBLIC_API_URL=http://localhost:8000
